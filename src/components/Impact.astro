---
const stats = [
  { number: "20", label: "Years running", suffix: "" },
  { number: "$100K+", label: "Raised in 2025, after expenses", suffix: "" },
  { number: "1,500+", label: "Attendees last year", suffix: "" },
  { number: "18", label: "Local youth organizations funded", suffix: "" },
];

const orgs = [
  "SCBA UMass Dartmouth Scholarship Fund", "Children's Advocacy Center of Bristol County",
  "Boys & Girls Clubs of New Bedford & Fall River", "Friendly Sons of St. Patrick",
  "United Way of Greater New Bedford", "Dennison Memorial Community Center",
  "STAR Kids Program", "Silvia Elementary School", "Alma del Mar School",
  "Global Learning Charter Public School", "Community Boating Center of New Bedford",
  "Friends of Jack Foundation", "Girls on the Run",
  "Junior Achievement of Southern Massachusetts", "Whaling City Baseball & Track and Field Club",
  "SEYAA", "ASAP", "Gnome Surf", "New Bedford High School Drama Club",
  "Whaling City Jr./Sr. High School",
];
---
<section class="impact section-pad" id="impact">
  <div class="wrap">
    <p class="eyebrow">Presented by SCBA</p>
    <h2>Every stein poured funds Southcoast youth.</h2>
    <p class="impact-lede">
      SCBA is a Southcoast nonprofit investing in at-risk youth across New
      Bedford, Fall River, and beyond. NB Oktoberfest is our largest
      fundraiser of the year, and proceeds go directly to a range of local
      youth-focused nonprofits — from scholarships and school programs to
      community centers, mentorship, and youth sports. Last year's numbers
      are below, and we're aiming higher for the 20th.
    </p>

    <div class="stat-grid">
      {stats.map((s) => (
        <div class="stat">
          <span class="stat-number">{s.number}</span>
          <span class="stat-label">{s.label}</span>
        </div>
      ))}
    </div>

    <div class="orgs-block">
      <p class="orgs-label">Organizations funded by SCBA</p>
      <ul class="orgs-list">
        {orgs.map((o) => <li>{o}</li>)}
      </ul>
    </div>
  </div>
</section>

<style>
  .impact-lede {
    max-width: 60ch;
    color: var(--text-muted);
    margin-top: 12px;
  }
  .stat-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
    margin-top: 48px;
  }
  .stat {
    background: var(--bg-panel);
    padding: 32px 20px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .stat-number {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3vw, 2.4rem);
    color: var(--sun);
  }
  .stat-label {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-muted);
    letter-spacing: 0.02em;
  }
  @media (max-width: 780px) {
    .stat-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .orgs-block {
    margin-top: 48px;
    padding-top: 40px;
    border-top: 1px solid var(--line);
  }
  .orgs-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: 18px;
  }
  .orgs-list {
    list-style: none;
    margin: 0;
    padding: 0;
    columns: 3;
    column-gap: 32px;
    font-size: 0.92rem;
    color: var(--text);
  }
  .orgs-list li {
    break-inside: avoid;
    padding: 6px 0;
    border-bottom: 1px dashed var(--line);
  }
  @media (max-width: 780px) {
    .orgs-list { columns: 1; }
  }
</style>
