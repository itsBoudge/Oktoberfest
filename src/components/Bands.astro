---
const supportActs = ["DJ", "Off Kilter", "Morrissey Blvd", "Seven Day Weekend"];
const headliner = "Quinn Sullivan";
---
<section class="bands section-pad" id="lineup">
  <div class="bands-bg" style="background-image: url('/images/bands/bands-bg.jpg');"></div>
  <div class="bands-scrim"></div>
  <div class="wrap bands-grid">
    <div class="bands-content">
      <p class="eyebrow eyebrow-light">Live On the Main Stage</p>
      <h2>This Year's Lineup</h2>

      <div class="headliner">
        <span class="headliner-label">Headliner</span>
        <span class="headliner-name">{headliner}</span>
      </div>

      <div class="support-acts">
        {supportActs.map((band) => <span class="support-act">{band}</span>)}
      </div>

      <p class="bands-note">Lineup subject to updates as we lock in set times.</p>
    </div>

    <div class="bands-art">
      <img
        src="/images/bands/quinn-sullivan.webp"
        alt="Quinn Sullivan illustrated portrait playing guitar"
      />
    </div>
  </div>
</section>

<style>
  .bands {
    position: relative;
    overflow: hidden;
    color: var(--parchment);
  }
  .bands-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center 30%;
  }
  .bands-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(17,20,34,0.88) 0%, rgba(17,20,34,0.82) 60%, rgba(17,20,34,0.92) 100%);
  }
  .bands-grid {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 40px;
    align-items: center;
  }
  .bands-content {
    text-align: left;
  }
  .bands h2 { color: var(--parchment); }
  .eyebrow-light { color: var(--sun-bright); }

  .headliner {
    margin: 36px 0 30px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .headliner-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--sun-bright);
  }
  .headliner-name {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    color: var(--parchment);
  }

  .support-acts {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-start;
    gap: 14px;
  }
  .support-act {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    padding: 10px 20px;
    border: 1px solid rgba(236,225,205,0.35);
    border-radius: 999px;
    color: var(--parchment);
  }

  .bands-note {
    margin-top: 30px;
    font-size: 0.8rem;
    color: rgba(236,225,205,0.6);
  }

  .bands-art {
    display: flex;
    justify-content: center;
  }
  .bands-art img {
    width: 100%;
    max-width: 420px;
    height: auto;
  }

  @media (max-width: 860px) {
    .bands-grid {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .bands-content { text-align: center; }
    .support-acts { justify-content: center; }
    .bands-art { order: -1; }
    .bands-art img { max-width: 280px; }
  }
</style>
