<section class="hero" id="top">
  <picture>
    <source media="(max-width: 720px)" srcset="/images/hero/mobile-hero.jpg" />
    <img
      src="/images/hero/desktop-hero.jpg"
      alt="New Bedford Oktoberfest live band on stage with a packed crowd"
      class="hero-img"
    />
  </picture>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    background: #e3d3b4;
    display: flex;
    justify-content: center;
  }
  .hero-img {
    width: 100%;
    height: auto;
    max-height: 88vh;
    display: block;
    object-fit: contain;
  }
</style>
